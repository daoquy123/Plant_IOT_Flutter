NODE_ENV=production
# Bind all interfaces (required for Nginx reverse proxy on the same host)
HOST=0.0.0.0
PORT=3000
API_KEY=a90cfc28468dc7b73eda44573bebb3a6d39981c92f449a9fc3cda4e56e113ce0
DB_PATH=./data/plant_iot.db
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=5
SENSOR_RETENTION_DAYS=30
IMAGE_RETENTION_DAYS=7
LOG_LEVEL=info
# Comma-separated allowed browser origins. Mobile apps often send no Origin (allowed). Empty = allow all.
# After HTTPS: add both: http://five-small-snowflake.site,https://five-small-snowflake.site
CORS_ORIGINS=http://five-small-snowflake.site,https://five-small-snowflake.site
# Trust first reverse proxy (Nginx) for X-Forwarded-Proto / client IP
TRUST_PROXY=1
